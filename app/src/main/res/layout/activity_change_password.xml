<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/app_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/change_password"
        android:textColor="@color/app_text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/currentPasswordInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/current_password"
        android:textColor="@color/app_text_primary"
        android:textColorHint="@color/app_text_secondary"
        android:inputType="textPassword"
        android:background="@drawable/custom_input_bg"
        android:padding="16dp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/newPasswordInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/new_password"
        android:textColor="@color/app_text_primary"
        android:textColorHint="@color/app_text_secondary"
        android:inputType="textPassword"
        android:background="@drawable/custom_input_bg"
        android:padding="16dp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/confirmPasswordInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/confirm_new_password"
        android:textColor="@color/app_text_primary"
        android:textColorHint="@color/app_text_secondary"
        android:inputType="textPassword"
        android:background="@drawable/custom_input_bg"
        android:padding="16dp"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/submitChangePasswordBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/change_password"
        android:textColor="@color/white"
        app:backgroundTint="@color/app_button"
        app:cornerRadius="20dp" />

</LinearLayout>
